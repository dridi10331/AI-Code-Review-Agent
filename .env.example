APP_NAME=AI Code Review Agent
ENVIRONMENT=dev
LOG_LEVEL=INFO

API_V1_PREFIX=/api/v1

# ============================================
# LLM Configuration
# ============================================
# Set USE_OLLAMA_ONLY=true to use only FREE local Ollama models (no API keys needed!)
# Set USE_OLLAMA_ONLY=false to use paid Claude/OpenAI APIs
USE_OLLAMA_ONLY=true

# Ollama Settings (Free Local Models - requires Ollama installed)
# Download from: https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=codellama
OLLAMA_SECONDARY_MODEL=llama3
OLLAMA_TERTIARY_MODEL=mistral
OLLAMA_TIMEOUT=120.0

# Paid provider keys below (usage is billed by token/requests).
# Only needed if USE_OLLAMA_ONLY=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/code_review

GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_PR_MAX_FILES=25
GITHUB_PR_MAX_FILE_CHARS=12000

AUTH_MODE=none
AUTH_API_KEYS=
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=

OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-code-review-agent
OTEL_EXPORTER_OTLP_ENDPOINT=

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_EMBEDDING_DIMENSION=128

CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=30
